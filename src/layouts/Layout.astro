---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = '亚萨诗班', description = '亚萨诗班官方网站 — 以歌声荣耀神' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title === '亚萨诗班' ? title : `${title} — 亚萨诗班`}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <!-- 顶部导航 -->
  <header class="site-header">
    <div class="container">
      <a href="/" class="logo">
        <span class="logo-icon">🎵</span>
        <span class="logo-text">亚萨诗班</span>
      </a>
      <button class="menu-toggle" aria-label="打开菜单" id="menuToggle">
        <span></span><span></span><span></span>
      </button>
      <nav class="main-nav" id="mainNav">
        <a href="/" class="nav-link">首页</a>
        <a href="/albums" class="nav-link">专辑</a>
        <a href="/admin" class="nav-link nav-link-admin">后台管理</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- 页脚 -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="footer-logo">🎵 亚萨诗班</div>
          <p class="footer-tagline">以歌声敬拜，以赞美荣耀</p>
        </div>
        <div class="footer-links">
          <h4>导航</h4>
          <a href="/">首页</a>
          <a href="/albums">专辑</a>
        </div>
        <div class="footer-verse">
          <h4>今日经文</h4>
          <blockquote>
            "你们要赞美耶和华！在他的圣所赞美他，在他显能力的穹苍赞美他。"
          </blockquote>
          <cite>— 诗篇 150:1</cite>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} 亚萨诗班 · 荣耀归于神</p>
      </div>
    </div>
  </footer>

  <script>
    // 移动端菜单切换
    const toggle = document.getElementById('menuToggle');
    const nav = document.getElementById('mainNav');
    toggle?.addEventListener('click', () => {
      nav?.classList.toggle('open');
      toggle.classList.toggle('active');
    });
    // 点击导航链接后关闭菜单
    nav?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        nav.classList.remove('open');
        toggle?.classList.remove('active');
      });
    });
  </script>
</body>
</html>
