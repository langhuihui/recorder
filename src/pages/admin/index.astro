---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="仪表盘">
  <div class="stats-grid" id="statsGrid">
    <div class="stat-card">
      <div class="stat-icon"><i class="icon icon-music icon-xl"></i></div>
      <div class="stat-value" id="statAlbumSongs">—</div>
      <div class="stat-label">专辑歌曲</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon"><i class="icon icon-folder icon-xl"></i></div>
      <div class="stat-value" id="statPracticeSongs">—</div>
      <div class="stat-label">练唱歌曲</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon"><i class="icon icon-disc icon-xl"></i></div>
      <div class="stat-value" id="statAlbums">—</div>
      <div class="stat-label">专辑总数</div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">快捷操作</div>
    <div class="form-actions">
      <a href="/admin/songs" class="btn btn-primary"><i class="icon icon-music"></i> 专辑歌曲</a>
      <a href="/admin/albums" class="btn btn-outline"><i class="icon icon-disc"></i> 管理专辑</a>
      <a href="/admin/practice" class="btn btn-outline"><i class="icon icon-folder"></i> 练唱歌曲</a>
      <a href="/albums" class="btn btn-ghost" target="_blank"><i class="icon icon-globe"></i> 查看前台</a>
    </div>
  </div>

  <div class="card mt-6">
    <div class="card-title"><i class="icon icon-book-open"></i> 今日灵修</div>
    <div class="about-verse">
      <blockquote>
        "你们歌颂神，歌颂他；歌颂我们的王，歌颂他。因为神是全地的王；你们要用悟性歌颂他。"
      </blockquote>
      <cite>— 诗篇 47:6-7</cite>
    </div>
  </div>
</AdminLayout>

<script>
  async function loadStats() {
    try {
      const [albumSongsRes, practiceSongsRes, albumsRes] = await Promise.all([
        fetch('/api/songs?limit=1&song_kind=album'),
        fetch('/api/songs?limit=1&song_kind=practice'),
        fetch('/api/albums?limit=1'),
      ]);
      const albumSongs = await albumSongsRes.json();
      const practiceSongs = await practiceSongsRes.json();
      const albums = await albumsRes.json();
      document.getElementById('statAlbumSongs')!.textContent = albumSongs.pagination?.total ?? '—';
      document.getElementById('statPracticeSongs')!.textContent = practiceSongs.pagination?.total ?? '—';
      document.getElementById('statAlbums')!.textContent = albums.pagination?.total ?? '—';
    } catch {}
  }
  loadStats();
</script>
