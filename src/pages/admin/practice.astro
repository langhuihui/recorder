---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="练唱文件">
  <div class="flex items-center justify-between gap-2 flex-wrap" style="margin-bottom:20px">
    <div>
      <div style="font-size:0.85rem;color:var(--text-muted)">管理练唱相关文件，供诗班成员下载使用</div>
    </div>
    <button class="btn btn-primary" onclick="document.getElementById('upload-modal').style.display='flex'">+ 上传文件</button>
  </div>

  <!-- 分类过滤 -->
  <div class="track-type-tabs" style="margin-bottom:20px" id="categoryTabs">
    <button class="track-tab active" data-cat="">全部</button>
    <button class="track-tab" data-cat="sheet"><i class="icon icon-file-text"></i> 歌谱</button>
    <button class="track-tab" data-cat="audio"><i class="icon icon-music"></i> 音频</button>
    <button class="track-tab" data-cat="video"><i class="icon icon-video"></i> 视频</button>
    <button class="track-tab" data-cat="doc"><i class="icon icon-clipboard"></i> 文档</button>
    <button class="track-tab" data-cat="other"><i class="icon icon-package"></i> 其他</button>
  </div>

  <!-- 文件列表 -->
  <div id="file-list" class="file-list">
    <div class="loading">加载中...</div>
  </div>
  <div id="file-pagination" class="pagination"></div>

  <!-- 上传模态框 -->
  <div id="upload-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:500;align-items:center;justify-content:center;padding:20px">
    <div class="card" style="max-width:500px;width:100%;max-height:90vh;overflow-y:auto">
      <div class="flex items-center justify-between" style="margin-bottom:20px">
        <h2 class="card-title" style="margin-bottom:0">上传练唱文件</h2>
        <button class="btn btn-ghost btn-sm" onclick="closeUploadModal()">✕ 关闭</button>
      </div>
      <div class="form-group">
        <label class="form-label">文件分类</label>
        <select id="upload-category" class="form-input">
          <option value="sheet">歌谱</option>
          <option value="audio">音频</option>
          <option value="video">视频</option>
          <option value="doc">文档</option>
          <option value="other">其他</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">文件描述（可选）</label>
        <input type="text" id="upload-desc" class="form-input" placeholder="如：2024年练习歌谱">
      </div>
      <div class="form-group">
        <label class="form-label">选择文件 <span class="required">*</span></label>
        <div class="upload-zone" id="practice-upload-zone">
          <div class="upload-icon"><i class="icon icon-folder icon-2xl"></i></div>
          <p>拖拽文件到此处或点击选择</p>
          <p class="hint">支持 PDF、图片、音频、视频等格式</p>
          <input type="file" id="practice-files" multiple hidden>
        </div>
        <div id="practice-file-list" style="margin-top:12px;display:flex;flex-direction:column;gap:6px"></div>
      </div>
      <div class="form-actions">
        <button class="btn btn-ghost" onclick="closeUploadModal()">取消</button>
        <button class="btn btn-primary" onclick="uploadPracticeFiles()">上传文件</button>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  const API = '/api';
  let currentCat = '';
  let currentPage = 1;
  let practiceFiles: File[] = [];

  function toast(msg: string, type = 'info') {
    const c = document.getElementById('toast-container');
    const el = document.createElement('div');
    el.className = `toast toast-${type}`;
    el.textContent = msg;
    c?.appendChild(el);
    setTimeout(() => el.remove(), 3500);
  }
  function showOverlay(text: string) {
    document.getElementById('upload-progress-text')!.textContent = text;
    (document.getElementById('upload-progress-bar') as HTMLElement).style.width = '0%';
    document.getElementById('upload-overlay')!.classList.remove('hidden');
  }
  function hideOverlay() { document.getElementById('upload-overlay')!.classList.add('hidden'); }
  function setProgress(p: number) { (document.getElementById('upload-progress-bar') as HTMLElement).style.width = p + '%'; }
  function formatDate(s: string) { return s ? new Date(s).toLocaleDateString('zh-CN') : ''; }
  function escapeHtml(s: string) {
    if (!s) return '';
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  function formatSize(bytes: number) {
    if (!bytes) return '';
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024*1024) return (bytes/1024).toFixed(1) + ' KB';
    return (bytes/(1024*1024)).toFixed(1) + ' MB';
  }

  function getCatIcon(cat: string) {
    const icons: Record<string,string> = { sheet:'<i class="icon icon-file-text"></i>', audio:'<i class="icon icon-music"></i>', video:'<i class="icon icon-video"></i>', doc:'<i class="icon icon-clipboard"></i>', other:'<i class="icon icon-package"></i>' };
    return icons[cat] || '<i class="icon icon-folder"></i>';
  }

  // Category tabs
  document.querySelectorAll('.track-tab[data-cat]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.track-tab[data-cat]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentCat = (btn as HTMLElement).dataset.cat!;
      loadFiles(1);
    });
  });

  async function loadFiles(page = 1) {
    currentPage = page;
    const listEl = document.getElementById('file-list')!;
    const pageEl = document.getElementById('file-pagination')!;
    listEl.innerHTML = '<div class="loading">加载中...</div>';
    try {
      const params = new URLSearchParams({ page: String(page), limit: '20' });
      if (currentCat) params.set('category', currentCat);
      const res = await fetch(`${API}/practice-files?${params}`);
      if (!res.ok) throw new Error('加载失败');
      const { data, pagination } = await res.json();
      if (!data || data.length === 0) {
        listEl.innerHTML = `<div class="empty-state"><div class="empty-icon"><i class="icon icon-folder icon-3xl"></i></div><p>暂无文件，点击上传按钮添加</p></div>`;
        pageEl.innerHTML = '';
        return;
      }
      listEl.innerHTML = data.map((file: any) => `
        <div class="file-row">
          <div class="file-icon">${getCatIcon(file.category)}</div>
          <div class="file-row-info">
            <div class="file-row-name">${escapeHtml(file.name)}</div>
            <div class="file-row-meta">${file.description ? escapeHtml(file.description) + ' · ' : ''}${formatSize(file.size)} · ${formatDate(file.created_at)}</div>
          </div>
          <div class="file-row-actions">
            <a href="${file.url}" target="_blank" class="btn btn-sm btn-outline">下载</a>
            <button class="btn btn-sm btn-danger" onclick="deleteFile('${file.id}','${escapeHtml(file.name)}')">删除</button>
          </div>
        </div>
      `).join('');
      if (pagination.totalPages > 1) {
        let html = '';
        for (let i = 1; i <= pagination.totalPages; i++) {
          html += `<button class="page-btn${i===page?' active':''}" onclick="loadFiles(${i})">${i}</button>`;
        }
        pageEl.innerHTML = html;
      } else pageEl.innerHTML = '';
    } catch(e: any) {
      listEl.innerHTML = `<div class="empty-state"><div class="empty-icon"><i class="icon icon-folder icon-3xl"></i></div><p>暂无练唱文件</p></div>`;
      pageEl.innerHTML = '';
    }
  }

  async function deleteFile(id: string, name: string) {
    if (!confirm(`确定要删除文件「${name}」吗？`)) return;
    try {
      const res = await fetch(`${API}/practice-files/${id}`, { method: 'DELETE' });
      const r = await res.json();
      if (!res.ok) throw new Error(r.error);
      toast('删除成功', 'success');
      loadFiles(currentPage);
    } catch(e: any) { toast(`删除失败: ${e.message}`, 'error'); }
  }

  // Upload modal
  function closeUploadModal() {
    document.getElementById('upload-modal')!.style.display = 'none';
    practiceFiles = [];
    renderPracticeFileList();
    (document.getElementById('practice-files') as HTMLInputElement).value = '';
  }

  function initPracticeUpload() {
    const zone = document.getElementById('practice-upload-zone')!;
    const input = document.getElementById('practice-files') as HTMLInputElement;
    zone.addEventListener('click', () => input.click());
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
    zone.addEventListener('drop', e => { e.preventDefault(); zone.classList.remove('drag-over'); addFiles((e as DragEvent).dataTransfer!.files); });
    input.addEventListener('change', () => { addFiles(input.files!); input.value = ''; });
  }

  function addFiles(files: FileList) {
    for (const f of files) practiceFiles.push(f);
    renderPracticeFileList();
  }

  function renderPracticeFileList() {
    const c = document.getElementById('practice-file-list')!;
    c.innerHTML = practiceFiles.map((f, i) => `
      <div style="display:flex;align-items:center;gap:10px;padding:8px 12px;background:var(--bg);border-radius:6px;border:1px solid var(--border)">
        <span>${f.name}</span>
        <span style="font-size:0.78rem;color:var(--text-muted);flex:1">${formatSize(f.size)}</span>
        <button onclick="removePracticeFile(${i})" style="background:none;border:none;color:#dc2626;cursor:pointer;font-size:1.1rem">×</button>
      </div>
    `).join('');
  }

  function removePracticeFile(i: number) {
    practiceFiles.splice(i, 1);
    renderPracticeFileList();
  }

  async function uploadPracticeFiles() {
    if (practiceFiles.length === 0) { toast('请选择文件', 'error'); return; }
    const category = (document.getElementById('upload-category') as HTMLSelectElement).value;
    const description = (document.getElementById('upload-desc') as HTMLInputElement).value.trim();
    try {
      showOverlay(`正在上传 (0/${practiceFiles.length})...`);
      for (let i = 0; i < practiceFiles.length; i++) {
        document.getElementById('upload-progress-text')!.textContent = `正在上传 ${i+1}/${practiceFiles.length}: ${practiceFiles[i].name}`;
        setProgress((i / practiceFiles.length) * 100);
        const form = new FormData();
        form.append('file', practiceFiles[i]);
        form.append('category', category);
        if (description) form.append('description', description);
        const res = await fetch(`${API}/practice-files`, { method: 'POST', body: form });
        const r = await res.json();
        if (!res.ok) throw new Error(r.error || '上传失败');
      }
      setProgress(100);
      hideOverlay();
      toast(`${practiceFiles.length} 个文件上传成功`, 'success');
      closeUploadModal();
      loadFiles(1);
    } catch(e: any) { hideOverlay(); toast(`上传失败: ${e.message}`, 'error'); }
  }

  // 挂载到 window 供 inline onclick 调用
  (window as any).closeUploadModal = closeUploadModal;
  (window as any).uploadPracticeFiles = uploadPracticeFiles;
  (window as any).deleteFile = deleteFile;
  (window as any).loadFiles = loadFiles;
  (window as any).removePracticeFile = removePracticeFile;

  document.addEventListener('DOMContentLoaded', () => {
    initPracticeUpload();
    loadFiles();
  });
</script>
