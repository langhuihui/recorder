---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="专辑歌曲">
  <div id="view-list" class="view active">
    <div class="flex items-center justify-between gap-2 flex-wrap" style="margin-bottom:20px">
      <div>
        <div style="font-size:0.85rem;color:var(--text-muted)">供信徒欣赏的专辑曲目；新建时必须选择所属专辑</div>
      </div>
      <button class="btn btn-primary" onclick="switchView('upload')">+ 上传专辑歌曲</button>
    </div>
    <div id="song-list" class="song-grid">
      <div class="loading">加载中...</div>
    </div>
    <div id="pagination" class="pagination"></div>
  </div>

  <div id="view-upload" class="view" style="display:none">
    <div class="flex items-center justify-between gap-2 flex-wrap" style="margin-bottom:20px">
      <h2 style="font-size:1.1rem;font-weight:700">上传专辑歌曲</h2>
      <button type="button" class="btn btn-ghost" onclick="switchView('list')">← 返回列表</button>
    </div>

    <div class="bili-upload-page">
      <section class="card bili-files-card">
        <h3 class="bili-section-title"><i class="icon icon-file-text"></i> 文件</h3>
        <p class="hint bili-files-hint">每首歌一条欣赏用音频；歌谱可选。可先只填写底部信息并保存，暂存的文件会在保存时自动上传；保存后也可继续拖入，会立即上传。</p>

        <div class="bili-audio-wrap">
          <div class="bili-audio-group">
            <h4><i class="icon icon-music"></i> 音频</h4>
            <div class="bili-audio-grid bili-acc-single">
              <div class="audio-slot-card upload-zone" data-slot-kind="acc" data-part="default">
                <span class="audio-slot-title">欣赏音频</span>
                <span class="audio-slot-line" id="acc-default-name">拖入或点击</span>
                <span class="part-status" id="acc-default-status"></span>
                <input type="file" id="acc-default" accept="audio/*" hidden />
              </div>
            </div>
          </div>
        </div>

        <div class="upload-zone bili-drop-main" id="sheet-upload-zone">
          <div class="upload-icon"><i class="icon icon-file-text icon-2xl"></i></div>
          <p><strong>歌谱</strong>（可选）</p>
          <p class="hint">点击或拖拽至此 · JPG / PNG / WEBP / PDF · 支持多个文件</p>
          <input type="file" id="sheet-files" multiple accept="image/*,.pdf" hidden>
        </div>
        <div id="sheet-preview" class="sheet-preview"></div>
      </section>

      <section class="card bili-form-card">
        <h3 class="bili-section-title"><i class="icon icon-clipboard"></i> 基本信息</h3>
        <div class="form-group">
          <label class="form-label" for="album-select">所属专辑 <span class="required">*</span></label>
          <select id="album-select" class="form-input">
            <option value="">请选择专辑…</option>
          </select>
          <p class="hint" style="margin-top:6px">保存后将加入该专辑；创建后不可在此修改所属专辑</p>
        </div>
        <div class="form-group">
          <label class="form-label" for="song-title">歌曲标题 <span class="required">*</span></label>
          <input type="text" id="song-title" class="form-input" placeholder="请输入歌曲标题">
        </div>
        <div class="form-group">
          <label class="form-label" for="song-artist">演唱者/作者</label>
          <input type="text" id="song-artist" class="form-input" placeholder="请输入演唱者或作者">
        </div>
        <div class="form-group">
          <label class="form-label" for="song-desc">描述</label>
          <textarea id="song-desc" class="form-input form-textarea" placeholder="请输入歌曲描述（可选）"></textarea>
        </div>
        <p id="song-id-badge" class="hint" style="display:none"></p>
        <div class="form-actions flex-wrap">
          <button type="button" class="btn btn-primary" onclick="saveSongInfo()">保存歌曲信息</button>
          <button type="button" class="btn btn-outline" onclick="finishAndBack()">完成并返回列表</button>
          <button type="button" class="btn btn-ghost" onclick="resetUploadForm()">清空重新开始</button>
        </div>
      </section>
    </div>
  </div>

  <div id="view-detail" class="view" style="display:none">
    <div class="flex items-center justify-between gap-2 flex-wrap" style="margin-bottom:20px">
      <h2 id="detail-title" style="font-size:1.1rem;font-weight:700">歌曲详情</h2>
      <button type="button" class="btn btn-ghost" id="detail-back-btn" onclick="switchView('list')">← 返回列表</button>
    </div>
    <div id="detail-content"></div>
  </div>

<style>
  .bili-upload-page {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 920px;
  }
  .bili-section-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 12px 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .bili-files-hint {
    margin: 0 0 16px 0;
  }
  .bili-drop-main {
    min-height: 160px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 24px 16px;
    border-radius: var(--radius-lg, 12px);
  }
  .bili-audio-wrap {
    margin-bottom: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .bili-audio-group h4 {
    font-size: 0.9rem;
    font-weight: 700;
    margin: 0 0 10px 0;
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--text-muted);
  }
  .bili-audio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 10px;
  }
  .audio-slot-card {
    min-height: 88px;
    padding: 10px 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 4px;
    border-radius: var(--radius, 8px);
    cursor: pointer;
  }
  .audio-slot-title {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text);
  }
  .audio-slot-line {
    font-size: 0.72rem;
    color: var(--text-muted);
    word-break: break-all;
    line-height: 1.3;
    max-width: 100%;
  }
  .audio-slot-card .part-status {
    font-size: 0.7rem;
    min-height: 1em;
  }
  .bili-form-card {
    margin-bottom: 32px;
  }
  .bili-acc-single {
    grid-template-columns: minmax(160px, 240px);
    max-width: 260px;
  }
  .detail-supply-slot {
    border: 2px dashed var(--border);
    border-radius: 10px;
    padding: 12px;
    min-height: 112px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .detail-supply-slot.has-audio {
    border-style: solid;
  }
  .detail-vocal-slots {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
  }
  .detail-sheet-drop {
    min-height: 80px;
    justify-content: center;
  }
</style>

<script src="../../scripts/admin-songs-page.ts"></script>
</AdminLayout>
