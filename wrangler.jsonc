{
"name": "asa-choir",
"compatibility_date": "2025-04-01",
"pages_build_output_dir": "./dist",
// R2 绑定 - 存储歌曲文件
"r2_buckets": [
{
"binding": "ASC_BUCKET",
"bucket_name": "asc"
}
],
// D1 绑定 - 存储歌曲元数据
"d1_databases": [
{
"binding": "ASC_DB",
"database_name": "asc",
"database_id": "ef113082-b115-4e5b-975b-9fae829cc0fa"
}
]
}
