page {
  background-color: #0f0f1a;
  color: #e4e4e7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

button {
  background: initial;
  margin: 0;
  padding: 0;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}
